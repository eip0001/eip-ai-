# ── Deployer ─────────────────────────────────────────────────────────────────
# Private key of the wallet that deploys the contract (no 0x prefix needed)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# ── RPC Endpoints ─────────────────────────────────────────────────────────────
# Base Sepolia (testnet) — free public endpoint works, Alchemy/Infura is more reliable
BASE_SEPOLIA_RPC=https://sepolia.base.org
# BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Base Mainnet
BASE_RPC=https://mainnet.base.org
# BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Basescan verification (optional) ─────────────────────────────────────────
# Get free key at https://basescan.org/myapikey
BASESCAN_API_KEY=
